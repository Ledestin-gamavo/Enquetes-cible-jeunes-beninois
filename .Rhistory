save(donnees_brutes, file = "donnees_n1.RData")
# Charger les bibliothèques
library(dplyr)
# Charger les données nettoyées
load("donnees_n3.RData")
# Recodage de l'âge (enlever "ans")
donnees_brutes$age <- as.numeric(gsub(" ans", "", donnees_brutes$age))
# Variable cible (acceptation)
donnees_brutes$accepte <- ifelse(
donnees_brutes$acceptation
%in% c("Oui, certainement", "Oui, probablement"),
1,
0)
cat("Taux d'acceptation :", round(mean(donnees_brutes$accepte) * 100, 1), "%\n")
# Recodage du revenu
donnees_brutes$revenu_num <- case_when(
donnees_brutes$revenu == "Moins de 50 000 FCFA" ~ 1,
donnees_brutes$revenu == "50 000 – 100 000 FCFA" ~ 2,
donnees_brutes$revenu == "101 000 – 200 000 FCFA" ~ 3,
donnees_brutes$revenu == "Plus de 200 000 FCFA" ~ 4,
TRUE ~ NA_real_
)
# Recodage de l'épargne
donnees_brutes$epargne_num <- case_when(
donnees_brutes$epargne == "Je n'épargne pas" ~ 0,
donnees_brutes$epargne == "Moins de 10 000 FCFA" ~ 1,
donnees_brutes$epargne == "10 000 – 30 000 FCFA" ~ 2,
donnees_brutes$epargne == "Plus de 30 000 FCFA" ~ 3,
TRUE ~ NA_real_
)
# Recodage de la tolérance au risque
donnees_brutes$risque_num <- case_when(
donnees_brutes$tolerance_risque == "Éviter toute perte (très prudent)" ~ 1,
donnees_brutes$tolerance_risque == "Accepter de petites variations (prudent)" ~ 2,
donnees_brutes$tolerance_risque == "Accepter des variations modérées pour un meilleur gain" ~ 3,
donnees_brutes$tolerance_risque == "Accepter des variations fortes pour un très haut gain" ~ 4,
TRUE ~ NA_real_
)
# Recodage de la patience financière
donnees_brutes$patience_num <- ifelse(
donnees_brutes$patience_financiere == "70 000 FCFA dans 6 mois",
1, 0
)
# Recodage de l'intérêt pour la finance
donnees_brutes$interet_num <- case_when(
donnees_brutes$interet_finance == "Oui, beaucoup" ~ 3,
donnees_brutes$interet_finance == "Oui, un peu" ~ 2,
donnees_brutes$interet_finance == "Non, pas vraiment" ~ 1,
donnees_brutes$interet_finance == "Non, pas du tout" ~ 0,
TRUE ~ NA_real_
)
# Afficher les résultats
cat("\n RÉSULTATS DU RECODAGE \n")
cat("Âge min :", min(donnees_brutes$age, na.rm = TRUE), "\n")
cat("Âge max :", max(donnees_brutes$age, na.rm = TRUE), "\n")
cat("Nombre total :", nrow(donnees_brutes), "répondants\n")
# Sauvegarde finale
save(donnees_brutes, file = "donnees_finales.RData")
write.csv(donnees_brutes, "donnees_finales.csv",
row.names = FALSE,
fileEncoding = "UTF-8")
